# Postgres
POSTGRES_USER=bug
POSTGRES_PASSWORD=bug
POSTGRES_DB=hopper
DATABASE_URL=postgres://bug:bug@db:5432/hopper

# Ollama
OLLAMA_URL=http://ollama:11434
OLLAMA_GEN_MODEL=llama3.2:3b
OLLAMA_EMBED_MODEL=nomic-embed-text

# Slack — two modes; pick one:
#
# Mode A: bot token (recommended for full duplicate-as-thread-reply support).
#   Requires installing a Slack app in your workspace with `chat:write` scope.
#   In a free personal Slack workspace this takes ~5 minutes.
#   When set, duplicates post as threaded replies on the parent bug's message.
SLACK_BOT_TOKEN=
SLACK_CHANNEL=

# Mode B: incoming webhook URL (no app install needed; works anywhere).
#   Limitation: webhooks don't return the message ts, so duplicates post as
#   new top-level messages with a "Duplicate of #X" prefix instead of threads.
SLACK_WEBHOOK_URL=

# Display name for the Slack channel (used in UI / seed data).
SLACK_CHANNEL_NAME=#bugs-triage

# API
PORT=3000

# Demo seed user password (Maya). Required on first boot to seed her hash.
DEMO_PASSWORD=bugtriage

# Secret used to sign session cookies. Generate with: `openssl rand -hex 32`.
# Rotating invalidates every active session.
SESSION_SECRET=
